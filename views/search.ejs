<!DOCTYPE html>
<<<htmlhtmlhtml lang="en">
<<<headheadhead>
    <<<metmetameta charset="UTF-8">
    <<<metmetameta name="viewport" content="width=device-width, initial-scale=1.0">
    <<<tittitletitle><%= title %></title>
    <<<scriptscriptscript src="https://cdn.tailwindcss.com"></script>
    <<<linklinklink rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <<<stylstylestyle>
        body { background-color: #0a0a0a; color: #ffffff; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .rating-badge { background: rgba(100, 100, 100, 0.7); }
    </style>
</head>
<<<bodybodybody class="min-h-screen">

    <!-- Nav -->
    <<<navnavnav class="fixed top-0 w-full z-50 glass px-6 py-3 flex items-center justify-between">
        <<<divdivdiv class="flex items-center gap-8">
            <<<aaaa href="/" class="text-2xl font-bold flex items-center gap-2">
                <<<iiii class="fa-solid fa-cat text-white"></i>
                <<spanspan>Cinevo</span>
            </a>
        </div>
        <<<divdivdiv class="flex items-center gap-4">
            <<<formformform action="/search" method="GET" class="relative">
                <<<inputinputinput type="text" name="q" placeholder="Search movies..." class="bg-gray-800 border border-gray-700 rounded-full px-4 py-1 text-sm w-64 focus:outline-none focus:ring-2 focus:ring-gray-600">
                <<<buttonbuttonbutton type="submit" class="absolute right-3 top-2 text-gray-500 hover:text-white">
                    <<<iiii class="fa-solid fa-magnifying-glass text-xs"></i>
                </button>
            </form>
        </div>
    </nav>

    <!-- Content -->
    <<<divdivdiv class="pt-24 px-6 md:px-12 max-w-7xl mx-auto">
        <<<divdivdiv class="flex justify-between items-center mb-8">
            <<<hhhh1 class="text-3xl font-bold"><<<%=%=%= title %></h1>
            <<<aaaa href="/" class="text-sm text-gray-400 hover:text-white flex items-center gap-1">
                <<<iiii class="fa-solid fa-house mr-1"></i> Home
            </a>
        </div>

        <% if (movies.length === 0) { %>
            <<<divdivdiv class="text-center py-20">
                <<<iiii class="fa-solid fa-magnifying-glass text-5xl text-gray-700 mb-4"></i>
                <<<pppp class="text-gray-500 text-xl">No movies found for "<<%=%= query %>"</p>
            </div>
        <% } else { %>
            <<<divdivdiv class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
                <% movies.forEach(movie => { %>
                    <<<aaaa href="/movie/<%= movie.id %>" class="group cursor-pointer">
                        <<<divdivdiv class="relative aspect-[2/3] rounded-xl overflow-hidden mb-2">
                            <<<imgimgimg src="<%= movie.image %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" alt="<%= movie.title %>">
                            <<<divdivdiv class="absolute top-2 left-2 rating-badge text-white text-[10px] font-bold px-1.5 py-0.5 rounded">
                                <%= movie.rating %>
                            </div>
                        </div>
                        <<<hhhh3 class="font-medium text-sm group-hover:text-purple-400 transition"><<<%=%=%= movie.title %></h3>
                        <<<pppp class="text-gray-500 text-xs"><<<%=%=%= movie.year %></p>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </div>

</body>
</html>
