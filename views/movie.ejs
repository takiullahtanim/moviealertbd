<!DOCTYPE html>
<<htmlhtml lang="en">
<<headhead>
    <<metameta charset="UTF-8">
    <<metameta name="viewport" content="width=device-width, initial-scale=1.0">
    <<titletitle><%= title %></title>
    <<scriptscript src="https://cdn.tailwindcss.com"></script>
    <<linklink rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <<stylestyle>
        body { background-color: #0a0a0a; color: #ffffff; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .player-container { aspect-ratio: 16/9; background: #000; position: relative; }
    </style>
</head>
<<bodybody class="min-h-screen">

    <!-- Simple Nav -->
    <<navnav class="fixed top-0 w-full z-50 glass px-6 py-3 flex items-center justify-between">
        <<aa href="/" class="text-2xl font-bold flex items-center gap-2">
            <<ii class="fa-solid fa-cat text-white"></i>
            <span>Cinevo</span>
        </a>
        <<aa href="/" class="text-sm text-gray-400 hover:text-white"><<ii class="fa-solid fa-arrow-left mr-2"></i> Back to Home</a>
    </nav>

    <!-- Player Section -->
    <<divdiv class="pt-24 px-6 md:px-12 max-w-6xl mx-auto">
        <<divdiv class="player-container rounded-2xl overflow-hidden shadow-2xl border border-gray-800">
            <<iframeiframe
                id="movie-player"
                src="https://vidsrc.to/embed/movie/<%= movie.id %>"
                class="w-full h-full"
                frameborder="0"
                allowfullscreen
                webkitallowfullscreen
                mozallowfullscreen>
            </iframe>
        </div>

        <<divdiv class="mt-8 flex flex-col md:flex-row gap-8">
            <<divdiv class="w-full md:w-1/3">
                <<imgimg src="<%= movie.poster %>" class="w-full rounded-2xl shadow-lg" alt="<%= movie.title %>">
            </div>
            <<divdiv class="w-full md:w-2/3">
                <<hh1 class="text-4xl font-bold mb-2"><<%=%= movie.title %></h1>
                <<divdiv class="flex items-center gap-4 mb-4 text-sm text-gray-400">
                    <<spanspan class="text-yellow-500 font-bold"><<ii class="fa-solid fa-star mr-1"></i> <%= movie.rating %></span>
                    <span><%= movie.releaseDate %></span>
                </div>
                <<pp class="text-gray-400 text-lg leading-relaxed mb-6">
                    <%= movie.overview %>
                </p>
                <<divdiv class="flex gap-4">
                    <<buttonbutton class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-2 rounded-full font-bold transition">
                        <<ii class="fa-solid fa-heart mr-2"></i> Add to Favorites
                    </button>
                    <<buttonbutton class="glass px-6 py-2 rounded-full font-bold hover:bg-white/10 transition">
                        <<ii class="fa-solid fa-share-nodes mr-2"></i> Share
                    </button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
